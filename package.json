{
  "name": "connectedone-mcp",
  "version": "0.2.0",
  "description": "MCP server for the ConnectedOne Website API — contacts, members, products, orders, forms, bookings, subscriber lists and webhooks",
  "license": "MIT",
  "type": "module",
  "bin": {
    "connectedone-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hiromu1126t-dotcom/connectedone-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "connectedone",
    "simvoly",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
